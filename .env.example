# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Configuration (for Push Notifications)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
VITE_FIREBASE_VAPID_KEY=your-vapid-key

# Admin/Testing Secret Keys (Change these in production!)
VITE_ADMIN_SECRET_KEY=your-admin-secret
VITE_TEACHER_SECRET_KEY=your-teacher-secret
VITE_STUDENT_SECRET_KEY=your-student-secret
VITE_MASTER_ADMIN_EMAIL=admin@yourinstitution.edu

# Development Mode (only use if network blocks Supabase)
# VITE_USE_MOCK_AUTH=true
